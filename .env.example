# REQUERIDO: Tu API key de Anthropic (Claude)
# Obtén una en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OPCIONAL: URL del MCP Server de DocuSign (solo para modo "En vivo")
# Default: https://mcp-d.docusign.com/mcp
DOCUSIGN_MCP_URL=https://mcp-d.docusign.com/mcp

# OPCIONAL: Puerto (Render lo asigna automáticamente)
PORT=3000
