# ═══════════════════════════════════════════════════════════
# DocuSign MCP Demo — Variables de Entorno
# ═══════════════════════════════════════════════════════════

# REQUERIDO: Tu API key de Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OPCIONAL: Puerto (Render lo asigna automáticamente)
PORT=3000

# ─── DocuSign (para modo "En vivo") ───────────────────────
# Integration Key (Client ID) de Apps and Keys
DOCUSIGN_INTEGRATION_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# User ID (GUID) — lo ves arriba en Apps and Keys
DOCUSIGN_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# API Account ID — lo ves en Apps and Keys
DOCUSIGN_ACCOUNT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# RSA Private Key en Base64 (convertir con: cat private.pem | base64 -w 0)
DOCUSIGN_RSA_PRIVATE_KEY=LS0tLS1CRUdJTi...
