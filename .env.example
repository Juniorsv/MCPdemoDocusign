# ═══════════════════════════════════════════════════════════
# DocuSign MCP Demo — Variables de Entorno
# ═══════════════════════════════════════════════════════════

# ─── REQUERIDO ────────────────────────────────────────────
# API key de Anthropic (Claude). Obtén una en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── SEGURIDAD (recomendado en producción) ───────────────
# Origen permitido para CORS. En producción es OBLIGATORIO configurarlo
# o el servidor bloqueará todas las requests cross-origin.
# Multiple orígenes: separados por coma.
# Ejemplo: https://docusign-mcp-demo.onrender.com,https://otro.example.com
ALLOWED_ORIGIN=http://localhost:3000

# Entorno. En "production" se activan: bloqueo CORS estricto,
# ocultamiento de stack traces, ocultamiento de detalles internos.
NODE_ENV=development

# Puerto (Render lo asigna automáticamente)
PORT=3000

# ─── DOCUSIGN SANDBOX (opcional, para modo "En vivo") ────
# Integration Key (Client ID) de Apps and Keys
DOCUSIGN_INTEGRATION_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# User ID (GUID) — lo ves arriba en Apps and Keys
DOCUSIGN_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# API Account ID — lo ves en Apps and Keys
DOCUSIGN_ACCOUNT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# RSA Private Key en formato PEM con \n literales para los saltos de línea.
# Ejemplo: -----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----
# IMPORTANTE: En Render, usa Secret Files en lugar de env vars planas
# para esta key cuando sea posible.
DOCUSIGN_RSA_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----
